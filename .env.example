# Copiar a .env en la RAÍZ (carga back/config.py). No commitear .env.
# Front: usá front/.env.local con NEXT_PUBLIC_* (valores fijados al hacer npm run build).
# Bóveda: archivo boveda_microservicio/.env.boveda con API_KEY_INTERNA = mismo secreto que BOVEDA_API_KEY_INTERNA.
#
# Si el navegador da 404 en /_next/static/chunks/*.js → proxy/nginx o deploy incompleto.
# Ver deploy/DESPLEGAR-FRONT.txt y deploy/nginx-next.example.conf

# --- Obligatorios backend ---
SECRET_KEY_SEGURIDAD=
DB_HOST=
DB_USER=
DB_PASSWORD=
DB_PORT=3306
DB_NAME=
GOOGLE_SHEET_ID=
GOOGLE_SERVICE_ACCOUNT_FILE=credencial_IA.json

# --- Nombres de hojas Google (opcionales; defaults en back/config.py) ---
# SHEET_NAME_ARTICULOS=Articulos  etc.

# --- JWT admin, AFIP, facturador, bóveda ---
ADMIN_TOKEN_DURATION_SECONDS=28800
AFIP_CUIT=
AFIP_CERT=
AFIP_KEY=
AFIP_PRODUCTION=false
FACTURACION_API_URL=http://127.0.0.1:8012/facturador/facturar-por-cantidad
BOVEDA_URL=http://127.0.0.1:8015
BOVEDA_API_KEY_INTERNA=

# --- CORS si el front está en otro dominio (coma = varios) ---
CORS_EXTRA_ORIGINS=

# --- Scheduler / Google Sheets (reducir cuota 429) ---
# Sync automático Sheets→DB cada N segundos (default 300 = 5 min). Antes estaba forzado a 10s.
# SYNC_INTERVAL_SECONDS=300
# SYNC_AUTO_ENABLED=true
# SYNC_QUEUE_RETRY_SECONDS=60
# SYNC_REFRESH_COMPANIES_SECONDS=300
# SYNC_INCLUDE_PROVEEDORES=false
# SHEETS_CACHE_TTL_MINUTES=30
# SHEETS_HEADERS_TTL_MINUTES=30
# SHEETS_QUOTA_BACKOFF_MINUTES=2

# --- Scanner / báscula (opcional) ---
# SCANNER_API_KEYS=
# SCANNER_ALLOWED_IPS=

# --- front/.env.local (ejemplo; no va en este archivo al runtime) ---
# NEXT_PUBLIC_API_URL=https://tu-api-publica
# NEXT_PUBLIC_SCALE_BAUD=9600
# NEXT_PUBLIC_SCALE_MIN_INTERVAL_MS=400

# Chromium / red: serví SIEMPRE el sitio por HTTPS; HSTS lo pone el hosting (Hostinger) o Nginx.
# El JWT va en localStorage: cualquier XSS compromete la sesión; cabeceras anti-clickjacking en next.config.

# PM2 / proxy local hacia uvicorn (opcional)
FORWARDED_ALLOW_IPS=127.0.0.1,::1
